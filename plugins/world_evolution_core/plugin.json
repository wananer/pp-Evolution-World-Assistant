{
  "name": "world_evolution_core",
  "display_name": "Evolution World Assistant",
  "version": "0.1.1",
  "enabled": true,
  "runtime": {
    "type": "plotpilot_plugin",
    "api_version": "0.2",
    "entry": "static/inject.js",
    "style": "static/style.css"
  },
  "capabilities": {
    "frontend_panel": true,
    "background_jobs": true,
    "llm": true,
    "context_injection": true,
    "chapter_postprocess": true,
    "novel_prehistory": true,
    "story_planning_context": true,
    "api2_control_card": true,
    "api2_custom_provider": true,
    "story_graph": true,
    "global_route_map": true,
    "route_conflict_detection": true,
    "compact_vector_capsules": true,
    "manual_rebuild": true,
    "rollback": true,
    "chapter_review": true
  },
  "hooks": [
    "after_novel_created",
    "before_story_planning",
    "before_context_build",
    "after_commit",
    "manual_rebuild",
    "rollback",
    "before_chapter_review",
    "after_chapter_review",
    "review_chapter"
  ],
  "route_aliases": [
    "evolution-world"
  ],
  "permissions": [
    "read_novel",
    "read_chapter",
    "write_plugin_storage",
    "use_llm",
    "inject_context",
    "read_plugin_storage"
  ],
  "frontend": {
    "scripts": [
      "static/inject.js"
    ],
    "styles": [
      "static/style.css"
    ]
  }
}
